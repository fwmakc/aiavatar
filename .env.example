# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username

# AI Provider (Anthropic-compatible endpoint)
AI_BASE_URL=https://api.kimi.com/coding/v1
AI_API_KEY=your_api_key_here
AI_MODEL=kimi-latest
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096

# Proxy (required if Telegram is blocked in your region)
PROXY_URL=http://user:pass@host:port

# Access control (comma-separated list of allowed user IDs or usernames)
ALLOWED_USERS=

# Group behavior
GROUP_ACTIVE_MODE=true
GROUP_SCREENING_INTERVAL_MIN=60
GROUP_CONTEXT_LIMIT=10
GROUP_REPLY_LIMIT_PER_HOUR=5

# Features
GUARD_ENABLED=true
TIT_FOR_TAT_MODE=true
CONTENT_ENGINE_ENABLED=true

# Ban settings
BAN_DURATION_HOURS=24

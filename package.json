{
  "name": "aiavatar",
  "version": "0.1.0",
  "description": "Telegram AI avatar bot with modular per-chat/persona configuration",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "vite build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "keywords": [
    "telegram",
    "bot",
    "ai",
    "avatar",
    "chatbot",
    "typescript"
  ],
  "license": "Apache-2.0",
  "main": "dist/main.js",
  "files": [
    "dist/",
    "data/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "https-proxy-agent": "^5.0.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.15",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "mock-fs": "^5.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-node": "^5.0.1",
    "vitest": "^4.1.7"
  }
}
